  "keyFeatures": [
    "Redis-backed job queues with rock-solid stability",
    "Delayed jobs and cron-based repeatable jobs",
    "Rate limiting and priority queues",
    "Automatic retries with customizable backoff strategies",
    "Sandboxed processor functions in separate processes",
    "Pause/resume functionality (global or local)",
    "Rich event system for job lifecycle monitoring",
    "Support for Redis clusters and connection reuse"
  ],
  "publicApiSurface": [
    "Queue(name, url?, opts?)",
    "Queue#process(name?, concurrency?, processor)",
    "Queue#add(name?, data, opts?)",
    "Queue#addBulk(jobs[])",
    "Queue#pause(isLocal?)",
    "Queue#resume(isLocal?)",
    "Queue#getJobs(types, start?, end?)",
    "Queue#clean(grace, status?, limit?)",
    "Queue#obliterate(opts?)",
    "Queue#on(event, handler)",
    "Job#progress(value?)",
    "Job#log(message)",
    "Job#getState()",
    "Job#retry()",
    "Job#remove()",
    "Events: completed, failed, progress, active, stalled, waiting, paused, resumed"
  ]
